{
  "allowed_commands": ["ls", "cat", "cp", "stat", "du", "hash", "version"],
  "allowed_buckets": [
    "gs://your-bucket-here",
    "gs://another-allowed-bucket"
  ],
  "blocked_flags": ["-d", "--delete", "-D"],
  "max_request_size_bytes": 10485760,
  "rate_limit_per_minute": 60,
  "log_file": "/tmp/gsutil-proxy.log"
}
